<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#F7F4EE"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btn_back_detail"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_field_input"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/text_black" />

        <TextView
            android:id="@+id/tv_detail_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Chi tiet phong"
            android:textColor="@color/text_black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_field_input"
            android:src="@android:drawable/ic_menu_share"
            android:tint="@color/text_black" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="235dp"
                android:background="@drawable/bg_hero_gradient">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#33000000" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="14dp"
                    android:background="#66000000"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="1 / 4"
                    android:textColor="@color/white"
                    android:textSize="9sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="14dp"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="36dp"
                        android:layout_height="27dp"
                        android:layout_marginStart="5dp"
                        android:background="#553A3428" />

                    <View
                        android:layout_width="36dp"
                        android:layout_height="27dp"
                        android:layout_marginStart="5dp"
                        android:background="#551E3040" />

                    <View
                        android:layout_width="36dp"
                        android:layout_height="27dp"
                        android:layout_marginStart="5dp"
                        android:background="#553A2828" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="16dp"
                        android:layout_height="6dp"
                        android:background="@color/accent_gold" />

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginStart="4dp"
                        android:background="#66FFFFFF" />

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginStart="4dp"
                        android:background="#66FFFFFF" />

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginStart="4dp"
                        android:background="#66FFFFFF" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tv_detail_room_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toStartOf="@id/layout_score_box"
                        android:textColor="@color/text_black"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="Phong Deluxe" />

                    <LinearLayout
                        android:id="@+id/layout_score_box"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:background="@color/primary_dark"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <TextView
                            android:id="@+id/tv_detail_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="9.2"
                            android:textColor="@color/accent_gold"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Xuat sac"
                            android:textColor="#99FFFFFF"
                            android:textSize="8sp" />
                    </LinearLayout>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_detail_hotel_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#FFF8E0"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textColor="#7A5E00"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        tools:text="Grand Palace · 4★" />

                    <TextView
                        android:id="@+id/tv_detail_availability_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="@color/green_badge_bg"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textColor="@color/green_badge_text"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        tools:text="Con 3 phong" />

                    <TextView
                        android:id="@+id/tv_detail_deal_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:background="#E6F0FB"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:textColor="#0C447C"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        tools:text="Dat truc tiep -15%" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@color/white"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_detail_area"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_black"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            tools:text="35 m²" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dien tich"
                            android:textColor="@color/text_grey"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_detail_bed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_black"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            tools:text="1 doi" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giuong"
                            android:textColor="@color/text_grey"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_detail_capacity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_black"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            tools:text="2 nguoi" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Suc chua"
                            android:textColor="@color/text_grey"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_detail_floor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_black"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            tools:text="Tang 2" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View TP"
                            android:textColor="@color/text_grey"
                            android:textSize="9sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@color/green_badge_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="8dp">

                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="@color/green_badge_text" />

                    <TextView
                        android:id="@+id/tv_detail_availability_line"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="@color/green_badge_text"
                        android:textSize="10sp"
                        tools:text="3 phong trong · Nhan phong 14:00 · Tra phong 12:00 · 17/04 → 19/04" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="MO TA PHONG"
                    android:textColor="@color/text_grey"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="#444444"
                    android:textSize="13sp"
                    tools:text="Mo ta phong deluxe" />

                <TextView
                    android:id="@+id/tv_detail_read_more"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Doc them →"
                    android:textColor="@color/green_badge_text"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="TIEN NGHI PHONG"
                    android:textColor="@color/text_grey"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:id="@+id/layout_detail_amenities"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="DICH VU THEM"
                    android:textColor="@color/text_grey"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layout_detail_services"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="TRANG THAI PHONG · TANG 2"
                    android:textColor="@color/text_grey"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layout_detail_floor_rooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="✓ Trong · ✗ Da co khach · ⟳ Dang don"
                    android:textColor="#BBBBBB"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="DANH GIA KHACH"
                    android:textColor="@color/text_grey"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layout_detail_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:background="@color/white"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIA / DEM"
                android:textColor="#BBBBBB"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tv_detail_old_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CCCCCC"
                android:textSize="10sp"
                android:textStyle="normal"
                tools:text="1.764.706 đ" />

            <TextView
                android:id="@+id/tv_detail_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="1.500.000 đ" />

            <TextView
                android:id="@+id/tv_detail_total_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/green_badge_text"
                android:textSize="9sp"
                tools:text="Tong 2 dem: 3.000.000 đ · Da gom VAT" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_book_now"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:background="@drawable/bg_button_search"
            android:paddingHorizontal="22dp"
            android:text="Dat phong ngay →"
            android:textAllCaps="false"
            android:textColor="@color/accent_gold"
            android:textStyle="bold"
            tools:ignore="HardcodedText" />
    </LinearLayout>
</LinearLayout>
