<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/btnBackHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Quay lại trang chủ"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/tvGuestTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Thông tin khách hàng"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#111827" />

        <TextView
            android:id="@+id/tvGuestDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Quản lý tài khoản và thông tin cá nhân"
            android:textSize="15sp"
            android:textColor="#6B7280" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin cá nhân"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Họ và tên"
                android:textStyle="bold"
                android:textColor="#374151" />

            <TextView
                android:id="@+id/tvFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#F3F4F6"
                android:padding="14dp"
                android:text="Nguyễn Văn A"
                android:textColor="#111827"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Email"
                android:textStyle="bold"
                android:textColor="#374151" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#F3F4F6"
                android:padding="14dp"
                android:text="example@gmail.com"
                android:textColor="#111827"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Số điện thoại"
                android:textStyle="bold"
                android:textColor="#374151" />

            <TextView
                android:id="@+id/tvPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#F3F4F6"
                android:padding="14dp"
                android:text="0123456789"
                android:textColor="#111827"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Địa chỉ"
                android:textStyle="bold"
                android:textColor="#374151" />

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="#F3F4F6"
                android:minLines="2"
                android:padding="14dp"
                android:text="Chưa cập nhật"
                android:textColor="#111827"
                android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Chức năng tài khoản"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111827" />

        <Button
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:minHeight="52dp"
            android:text="Đổi mật khẩu"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnUpdateInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="52dp"
            android:text="Cập nhật thông tin cá nhân"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnForgotPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="52dp"
            android:text="Quên mật khẩu"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnBookingHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="52dp"
            android:text="Lịch sử booking"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="52dp"
            android:text="Đăng xuất"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/panelChangePassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đổi mật khẩu"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <EditText
                android:id="@+id/edtOldPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Nhập mật khẩu cũ"
                android:inputType="textPassword"
                android:padding="14dp" />

            <EditText
                android:id="@+id/edtNewPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Nhập mật khẩu mới"
                android:inputType="textPassword"
                android:padding="14dp" />

            <EditText
                android:id="@+id/edtConfirmNewPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Nhập lại mật khẩu mới"
                android:inputType="textPassword"
                android:padding="14dp" />

            <Button
                android:id="@+id/btnSubmitChangePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Lưu mật khẩu mới"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panelUpdateInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cập nhật thông tin cá nhân"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <EditText
                android:id="@+id/edtUpdateFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Họ và tên"
                android:inputType="textPersonName"
                android:padding="14dp" />

            <EditText
                android:id="@+id/edtUpdateEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:padding="14dp" />

            <EditText
                android:id="@+id/edtUpdatePhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Số điện thoại"
                android:inputType="phone"
                android:padding="14dp" />

            <EditText
                android:id="@+id/edtUpdateAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Địa chỉ"
                android:inputType="textPostalAddress"
                android:minLines="2"
                android:padding="14dp" />

            <Button
                android:id="@+id/btnSubmitUpdateInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Lưu thông tin mới"
                android:textAllCaps="false" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>