<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F4">

    <LinearLayout
        android:id="@+id/headerHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16361F"
        android:paddingStart="20dp"
        android:paddingTop="22dp"
        android:paddingEnd="20dp"
        android:paddingBottom="22dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackHistory"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:text="← Trở lại"
            android:textAllCaps="false"
            android:textColor="#355E3B"
            android:textStyle="bold"
            app:backgroundTint="#EAF3EA"
            app:cornerRadius="16dp"
            app:strokeColor="#AFC5B2"
            app:strokeWidth="1dp" />

        <TextView
            android:id="@+id/tvHistoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Lịch sử booking"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Các booking đã thanh toán và hoàn tất"
            android:textColor="#D7E5D9"
            android:textSize="14sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerHistory"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvEmptyHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chưa có booking nào đã thanh toán và hoàn tất."
                android:textColor="#6B7D6E"
                android:textSize="15sp"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutHistoryList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>