<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panelUpdateInfo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="20dp"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cập nhật thông tin cá nhân"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#111827" />

    <EditText
        android:id="@+id/edtUpdateFullName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Họ và tên"
        android:inputType="textPersonName"
        android:padding="14dp" />

    <EditText
        android:id="@+id/edtUpdateEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:padding="14dp" />

    <EditText
        android:id="@+id/edtUpdatePhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Số điện thoại"
        android:inputType="phone"
        android:padding="14dp" />

    <EditText
        android:id="@+id/edtUpdateCitizenId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Căn cước công dân"
        android:inputType="number"
        android:padding="14dp" />

    <EditText
        android:id="@+id/edtUpdateAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Địa chỉ"
        android:inputType="textPostalAddress"
        android:minLines="2"
        android:gravity="top|start"
        android:padding="14dp" />

    <Button
        android:id="@+id/btnSubmitUpdateInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Lưu"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/btnCancelUpdateInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Hủy"
        android:textAllCaps="false" />

</LinearLayout>