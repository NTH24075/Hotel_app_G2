<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="vertical"
            android:padding="22dp"
            android:gravity="center_vertical"
            android:background="@drawable/bg_header">

            <TextView
                android:id="@+id/txtMainTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Receptionist Dashboard"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/txtMainSubTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Chọn chức năng cần thao tác"
                android:textColor="#D6E4FF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Xin chào, Lễ tân"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- quick note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="14dp"
            android:padding="14dp"
            android:orientation="vertical"
            android:background="@drawable/bg_booking_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hôm nay bạn có thể"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="#0F172A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="• Theo dõi danh sách booking\n• Tìm kiếm và lọc booking\n• Xem nhanh trạng thái phòng"
                android:textSize="14sp"
                android:textColor="#475569" />
        </LinearLayout>

        <!-- chức năng -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="18dp"
            android:text="Chức năng chính"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#0F172A" />

        <!-- card booking -->
        <LinearLayout
            android:id="@+id/cardBooking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_dashboard_card_blue"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="📋"
                android:textSize="28sp"
                android:background="@drawable/bg_icon_circle_light" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quản lý booking"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#0F172A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Xem danh sách, tìm kiếm, lọc booking và mở chi tiết booking."
                    android:textSize="14sp"
                    android:textColor="#334155" />
            </LinearLayout>
        </LinearLayout>

        <!-- card room status -->
        <LinearLayout
            android:id="@+id/cardRoomStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="12dp"
            android:padding="16dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_dashboard_card_yellow"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="🏨"
                android:textSize="28sp"
                android:background="@drawable/bg_icon_circle_light" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trạng thái phòng"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#0F172A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Xem nhanh phòng trống, đang ở, đang dọn hoặc bảo trì."
                    android:textSize="14sp"
                    android:textColor="#334155" />
            </LinearLayout>
        </LinearLayout>

        <!-- logout -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="22dp"
            android:text="Đăng xuất" />

    </LinearLayout>
</ScrollView>