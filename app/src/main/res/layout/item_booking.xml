<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/bg_booking_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtBookingCode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BK20260501006"
            android:textStyle="bold"
            android:textSize="17sp"
            android:textColor="#0F172A" />

        <TextView
            android:id="@+id/txtBookingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#B45309"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/bg_status_orange" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtGuestName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Kiên Nhân"
        android:textSize="15sp"
        android:textColor="#475569" />

    <TextView
        android:id="@+id/txtRoomType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Loại phòng: Deluxe Twin"
        android:textSize="14sp"
        android:textColor="#334155" />

    <TextView
        android:id="@+id/txtDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Ngày ở: 2026-05-25 → 2026-05-27"
        android:textSize="14sp"
        android:textColor="#334155" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thanh toán:"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#475569" />

        <TextView
            android:id="@+id/txtPaymentStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Paid"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#15803D"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/bg_status_green" />
    </LinearLayout>

</LinearLayout>